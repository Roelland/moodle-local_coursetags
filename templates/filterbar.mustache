{{!
    @template local_coursetags/filterbar

    Tag filter input appended to the #action_bar .d-flex toolbar row.
    The active-chips container is created and placed by the AMD module.

    Example context (json): {}
}}
<div class="local-coursetags-filter-input-wrap ms-2">
    <input type="text"
           class="form-control local-coursetags-input"
           placeholder="{{#str}} filterplaceholder, local_coursetags {{/str}}"
           autocomplete="off"
           aria-label="{{#str}} filterplaceholder, local_coursetags {{/str}}"
           aria-autocomplete="list">
    <ul class="local-coursetags-suggestions list-unstyled" role="listbox" hidden></ul>
</div>
