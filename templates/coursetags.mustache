{{!
    @template local_coursetags/coursetags

    Renders a row of tag badge links for a course card or list item.
    Injected by local_coursetags/coursetags AMD module into each course element.

    Example context (json):
    {
        "tags": [
            { "id": 1, "rawname": "Mathematics", "tagurl": "/tag/index.php?id=1" },
            { "id": 2, "rawname": "Science",     "tagurl": "/tag/index.php?id=2" }
        ]
    }
}}
<div class="local-coursetags d-flex flex-wrap gap-1 mt-2">
    {{#tags}}
    <a href="{{tagurl}}"
       class="local-coursetags-badge badge rounded-pill text-decoration-none"
       title="{{rawname}}">
        {{rawname}}
    </a>
    {{/tags}}
</div>
